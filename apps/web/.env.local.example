# =============================================================================
# Pocket Room Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings: https://app.supabase.com
# Project Settings > API

# Public Supabase URL (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key (safe to expose to client, used for client-side auth)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key (NEVER expose to client - server-side only)
# Used for admin operations and testing
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# Gate Auth OAuth Providers (User Authentication)
# -----------------------------------------------------------------------------
# These are used for user login via Supabase Auth
# Configure in Supabase Dashboard: Authentication > Providers

# Google OAuth (for user login)
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_AUTH_CLIENT_ID=your_google_oauth_client_id
# Note: Google OAuth secret is configured in Supabase Dashboard, not here

# Feishu (Lark) OAuth (for user login)
# Get from: https://open.feishu.cn/app
NEXT_PUBLIC_FEISHU_AUTH_APP_ID=your_feishu_app_id
# Note: Feishu secret is configured in Supabase Dashboard, not here

# WeChat OAuth (for user login)
# Get from: https://open.weixin.qq.com/
NEXT_PUBLIC_WECHAT_AUTH_APP_ID=your_wechat_app_id
# Note: WeChat secret is configured in Supabase Dashboard, not here

# -----------------------------------------------------------------------------
# Provider Binding OAuth (AI Service Provider Authorization)
# -----------------------------------------------------------------------------
# These are used for binding external AI service accounts (OpenAI, Google AI, etc.)
# Users authorize Pocket Room to access their AI service accounts

# OpenAI OAuth (for ChatGPT API access)
# Get from: https://platform.openai.com/account/api-keys
OPENAI_CLIENT_ID=your_openai_client_id
OPENAI_CLIENT_SECRET=your_openai_client_secret
OPENAI_REDIRECT_URI=http://localhost:3000/api/oauth/callback/openai

# Google AI (Gemini) OAuth (for Gemini API access)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_AI_CLIENT_ID=your_google_ai_client_id
GOOGLE_AI_CLIENT_SECRET=your_google_ai_client_secret
GOOGLE_AI_REDIRECT_URI=http://localhost:3000/api/oauth/callback/google

# Anthropic OAuth (for Claude API access)
# Get from: https://console.anthropic.com/
ANTHROPIC_CLIENT_ID=your_anthropic_client_id
ANTHROPIC_CLIENT_SECRET=your_anthropic_client_secret
ANTHROPIC_REDIRECT_URI=http://localhost:3000/api/oauth/callback/anthropic

# -----------------------------------------------------------------------------
# Token Encryption
# -----------------------------------------------------------------------------
# Used to encrypt OAuth tokens before storing in database
# Generate a secure 32-byte key and encode as base64:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=your_32_byte_base64_encoded_encryption_key

# -----------------------------------------------------------------------------
# Next.js Configuration
# -----------------------------------------------------------------------------
# Public app URL (used for OAuth callbacks and absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# -----------------------------------------------------------------------------
# Optional: Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features during development
NEXT_PUBLIC_ENABLE_BROWSER_EXTENSION=true
NEXT_PUBLIC_ENABLE_COMPANION=true
NEXT_PUBLIC_ENABLE_SEGMENT_SHARING=true

# -----------------------------------------------------------------------------
# Optional: Logging and Monitoring
# -----------------------------------------------------------------------------
# Sentry DSN (for error tracking in production)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Optional: Rate Limiting
# -----------------------------------------------------------------------------
# API rate limits (requests per minute)
RATE_LIMIT_API=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_AI_INVOCATION=20
