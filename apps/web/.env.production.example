# =============================================================================
# Pocket Room Production Environment Variables
# =============================================================================
# This file contains the production environment variable template
# Configure these in Vercel Dashboard > Settings > Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (PRODUCTION)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# -----------------------------------------------------------------------------
# Provider Binding OAuth (PRODUCTION)
# -----------------------------------------------------------------------------
# Update redirect URIs to production domain

# OpenAI
OPENAI_CLIENT_ID=your_openai_client_id
OPENAI_CLIENT_SECRET=your_openai_client_secret
OPENAI_REDIRECT_URI=https://your-domain.com/api/oauth/callback/openai

# Google AI
GOOGLE_AI_CLIENT_ID=your_google_ai_client_id
GOOGLE_AI_CLIENT_SECRET=your_google_ai_client_secret
GOOGLE_AI_REDIRECT_URI=https://your-domain.com/api/oauth/callback/google

# Anthropic
ANTHROPIC_CLIENT_ID=your_anthropic_client_id
ANTHROPIC_CLIENT_SECRET=your_anthropic_client_secret
ANTHROPIC_REDIRECT_URI=https://your-domain.com/api/oauth/callback/anthropic

# -----------------------------------------------------------------------------
# Token Encryption (PRODUCTION)
# -----------------------------------------------------------------------------
# Generate a NEW secure key for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=your_production_encryption_key

# -----------------------------------------------------------------------------
# Next.js Configuration (PRODUCTION)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# -----------------------------------------------------------------------------
# Optional: Monitoring (PRODUCTION)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=warn

# -----------------------------------------------------------------------------
# Optional: Rate Limiting (PRODUCTION)
# -----------------------------------------------------------------------------
RATE_LIMIT_API=100
RATE_LIMIT_AUTH=20
RATE_LIMIT_AI_INVOCATION=30
