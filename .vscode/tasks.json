{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "启动开发服务器",
      "type": "npm",
      "script": "dev",
      "path": "apps/web",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "运行测试 (监听模式)",
      "type": "npm",
      "script": "test:watch",
      "path": "apps/web",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true
    },
    {
      "label": "构建生产版本",
      "type": "npm",
      "script": "build",
      "path": "apps/web",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "运行 Lint 检查",
      "type": "npm",
      "script": "lint",
      "path": "apps/web",
      "problemMatcher": ["$eslint-stylish"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "测试覆盖率报告",
      "type": "npm",
      "script": "test:coverage",
      "path": "apps/web",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
